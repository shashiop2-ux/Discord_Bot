# Copy this file to ".env" and fill in your own values.
# Never commit your real .env file or share your token publicly.

# From the Discord Developer Portal -> Your App -> Bot -> Token
DISCORD_TOKEN=your-bot-token-here

# From the Discord Developer Portal -> Your App -> General Information -> Application ID
CLIENT_ID=your-application-id-here

# Right-click your server icon (with Developer Mode on) -> Copy Server ID
# Used so slash commands register instantly in this one server (for testing).
GUILD_ID=your-server-id-here

# The exact Discord username (not nickname) of the person to auto-greet on startup.
# Leave blank to disable the auto-greet feature.
GREET_USERNAME=c_a_l_l
